{
  "name": "confluent-mac",
  "version": "1.0.0",
  "description": "ConFluent — Auto-translate what you type. Mac Desktop App.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --mac",
    "pack": "electron-builder --mac --dir"
  },
  "author": "ConFluent",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "electron-store": "^8.2.0",
    "node-global-key-listener": "^0.3.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.confluent.translator",
    "productName": "ConFluent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-overlay.js",
      "preload-dictation.js",
      "src/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.png",
      "target": [
        "dmg"
      ],
      "darkModeSupport": true,
      "hardenedRuntime": true
    },
    "dmg": {
      "title": "ConFluent",
      "iconSize": 80,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}